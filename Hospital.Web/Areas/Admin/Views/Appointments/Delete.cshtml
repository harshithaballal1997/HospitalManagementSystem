@model Hospital.ViewModels.AppointmentViewModel

@{
    ViewData["Title"] = "Delete Appointment";
}

<div class="container px-4 py-4" style="max-width:600px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-danger"><i class="fas fa-trash me-2"></i>Delete Appointment</h1>
            <p class="text-muted small mb-0">This action cannot be undone.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>

    <div class="modern-card shadow-sm border-0 border-start border-danger border-4">
        <div class="alert alert-danger border-0 bg-danger bg-opacity-10 rounded-3 mb-4">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Are you sure?</strong> You are about to permanently delete this appointment. This cannot be undone.
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6">
                <p class="text-muted small mb-1 fw-bold">Patient</p>
                <p class="fw-bold mb-0">@Model.PatientName</p>
            </div>
            <div class="col-6">
                <p class="text-muted small mb-1 fw-bold">Doctor</p>
                <p class="fw-bold mb-0">@Model.DoctorName</p>
            </div>
            <div class="col-6">
                <p class="text-muted small mb-1 fw-bold">Date & Time</p>
                <p class="fw-bold mb-0">@Model.AppointmentDate.ToString("MMM dd, yyyy") — @Model.TimeSlot</p>
            </div>
            <div class="col-6">
                <p class="text-muted small mb-1 fw-bold">Status</p>
                <p class="fw-bold mb-0">@Model.Status</p>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger px-4">
                    <i class="fas fa-trash me-1"></i> Yes, Delete Permanently
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
