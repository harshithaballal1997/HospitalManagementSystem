@model Hospital.ViewModels.AppointmentViewModel

@{
    ViewData["Title"] = "Reschedule Appointment";
}

<div class="container px-4 py-4" style="max-width:760px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-primary"><i class="fas fa-calendar-alt me-2"></i>Reschedule Appointment</h1>
            <p class="text-muted small mb-0">Update the date, time, or status of this booking.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>

    <div class="modern-card shadow-sm border-0">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="alert alert-danger small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-muted">Patient</label>
                    <select asp-for="PatientId" asp-items="ViewBag.Patients" class="form-select bg-light border-0">
                        <option value="">-- Select Patient --</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-muted">Doctor</label>
                    <select id="doctorSelect" asp-for="DoctorId" asp-items="ViewBag.Doctors" class="form-select bg-light border-0">
                        <option value="">-- Select Doctor --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Date</label>
                    <input type="date" asp-for="AppointmentDate" class="form-control bg-light border-0" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Time Slot</label>
                    <select id="slotSelect" asp-for="TimeSlot" class="form-select bg-light border-0">
                        <option value="@Model.TimeSlot">@Model.TimeSlot (current)</option>
                    </select>
                    <div id="slotSpinner" class="text-muted small mt-1" style="display:none;"><i class="fas fa-spinner fa-spin me-1"></i>Loading slots...</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Status</label>
                    <select asp-for="Status" class="form-select bg-light border-0">
                        <option value="Pending">Pending</option>
                        <option value="Confirmed">Confirmed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label small fw-bold text-muted">Reason / Notes</label>
                    <textarea asp-for="Description" class="form-control bg-light border-0" rows="3"></textarea>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-medical btn-medical-edit px-4">
                    <i class="fas fa-save me-1"></i> Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function loadSlots() {
        const doctorId = document.getElementById('doctorSelect').value;
        const date = document.querySelector('[name="AppointmentDate"]').value;
        const slotSelect = document.getElementById('slotSelect');
        const spinner = document.getElementById('slotSpinner');

        if (!doctorId || !date) return;

        spinner.style.display = 'block';
        const currentSlot = '@Model.TimeSlot';

        fetch(`/Admin/Appointments/GetAvailableSlots?doctorId=${doctorId}&date=${date}`)
            .then(r => r.json())
            .then(slots => {
                spinner.style.display = 'none';
                slotSelect.innerHTML = '';
                // Always include the current slot
                if (currentSlot) slotSelect.add(new Option(currentSlot + ' (current)', currentSlot));
                slots.filter(s => s !== currentSlot).forEach(s => slotSelect.add(new Option(s, s)));
            });
    }
    document.getElementById('doctorSelect').addEventListener('change', loadSlots);
    document.querySelector('[name="AppointmentDate"]').addEventListener('change', loadSlots);
</script>
}
