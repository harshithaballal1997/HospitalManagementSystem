@model Hospital.ViewModels.AppointmentViewModel

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="container px-4 py-4" style="max-width:760px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-primary"><i class="fas fa-calendar-check me-2"></i>Appointment Details</h1>
            <p class="text-muted small mb-0">Full summary of this booking.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>

    <div class="modern-card shadow-sm border-0">
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="p-3 bg-medical-light rounded-3">
                    <p class="small text-muted fw-bold mb-1"><i class="fas fa-user-injured me-1 text-primary"></i>Patient</p>
                    <h5 class="fw-bold mb-0 text-dark">@Model.PatientName</h5>
                </div>
            </div>
            <div class="col-md-6">
                <div class="p-3 bg-medical-light rounded-3">
                    <p class="small text-muted fw-bold mb-1"><i class="fas fa-user-md me-1 text-primary"></i>Doctor</p>
                    <h5 class="fw-bold mb-0 text-dark">@Model.DoctorName</h5>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 border rounded-3">
                    <p class="small text-muted fw-bold mb-1"><i class="fas fa-calendar me-1 text-primary"></i>Date</p>
                    <h6 class="fw-bold mb-0">@Model.AppointmentDate.ToString("dddd, MMM dd yyyy")</h6>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 border rounded-3">
                    <p class="small text-muted fw-bold mb-1"><i class="fas fa-clock me-1 text-primary"></i>Time Slot</p>
                    <h6 class="fw-bold mb-0">@Model.TimeSlot</h6>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3 border rounded-3">
                    <p class="small text-muted fw-bold mb-1"><i class="fas fa-tag me-1 text-primary"></i>Status</p>
                    @{
                        var sc = Model.Status switch { "Confirmed" => "success", "Cancelled" => "danger", _ => "warning" };
                    }
                    <span class="badge bg-@sc bg-opacity-15 text-@sc px-3 py-2 fw-bold">@Model.Status</span>
                </div>
            </div>
            <div class="col-12">
                <div class="p-3 border rounded-3">
                    <p class="small text-muted fw-bold mb-1"><i class="fas fa-notes-medical me-1 text-primary"></i>Reason/Notes</p>
                    <p class="mb-0 text-dark">@(Model.Description ?? "No notes provided.")</p>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-medical btn-medical-edit">
                <i class="fas fa-calendar-alt me-1"></i> Reschedule
            </a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-medical btn-medical-delete">
                <i class="fas fa-trash me-1"></i> Delete
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </div>
</div>
