@model Hospital.ViewModels.AppointmentViewModel

@{
    ViewData["Title"] = "New Appointment";
}

<div class="container px-4 py-4" style="max-width:860px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-primary"><i class="fas fa-plus-circle me-2"></i>New Appointment</h1>
            <p class="text-muted small mb-0">Create a new appointment on behalf of a patient.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>

    <div class="modern-card shadow-sm border-0">
        <form asp-action="Create" method="post" id="createForm">
            @Html.AntiForgeryToken()
            <!-- Hidden field to hold selected time slot -->
            <input type="hidden" name="TimeSlot" id="selectedSlotInput" />

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger small mb-3">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-muted">Patient</label>
                    <select asp-for="PatientId" asp-items="ViewBag.Patients" class="form-select bg-light border-0 py-2">
                        <option value="">-- Select Patient --</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-muted">Doctor</label>
                    <select id="doctorSelect" asp-for="DoctorId" asp-items="ViewBag.Doctors" class="form-select bg-light border-0 py-2">
                        <option value="">-- Select Doctor --</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold text-muted">Date</label>
                    <input type="date" id="dateInput" asp-for="AppointmentDate" class="form-control bg-light border-0 py-2"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-12">
                    <label class="form-label small fw-bold text-muted">Reason / Notes</label>
                    <textarea asp-for="Description" class="form-control bg-light border-0" rows="3"
                              placeholder="Optional: Describe symptoms or reason for visit..."></textarea>
                </div>
            </div>

            <!-- Time Slot Section -->
            <div id="slotSection" class="mb-4">
                <label class="form-label small fw-bold text-muted"><i class="fas fa-clock me-1"></i>Available Time Slots</label>

                <div id="slotPlaceholder" class="p-4 bg-light rounded-3 text-center text-muted small">
                    <i class="fas fa-calendar-day fa-2x mb-2 d-block text-light"></i>
                    Please select a Doctor and Date above to see available slots.
                </div>

                <div id="slotLoader" style="display:none;" class="p-3 text-center text-muted small">
                    <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                    Checking availability...
                </div>

                <div id="slotGrid" class="row g-2" style="display:none;"></div>

                <div id="slotError" style="display:none;" class="alert alert-warning small mt-2">
                    <i class="fas fa-info-circle me-1"></i>
                    No available slots for this day. Please pick another date or doctor.
                </div>

                <div id="selectedSlotBadge" style="display:none;" class="mt-2">
                    <span class="badge bg-primary px-3 py-2">
                        <i class="fas fa-check me-1"></i>
                        Selected: <strong id="selectedSlotLabel"></strong>
                    </span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" id="submitBtn" class="btn btn-medical btn-medical-create px-4" disabled>
                    <i class="fas fa-save me-1"></i> Create Appointment
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<style>
    .slot-btn {
        border: 1px solid #dee2e6;
        background: white;
        border-radius: 8px;
        padding: 8px 10px;
        font-size: 0.82rem;
        font-weight: 500;
        width: 100%;
        text-align: center;
        cursor: pointer;
        transition: all 0.18s ease;
        color: #495057;
    }
    .slot-btn:hover { background: #0056b3; color: white; border-color: #0056b3; }
    .slot-btn.selected { background: #0056b3; color: white; border-color: #0056b3; font-weight: 700; }
</style>
<script>
    const doctorSel = document.getElementById('doctorSelect');
    const dateInput = document.getElementById('dateInput');
    const slotInput = document.getElementById('selectedSlotInput');
    const submitBtn = document.getElementById('submitBtn');
    const slotPlaceholder = document.getElementById('slotPlaceholder');
    const slotLoader = document.getElementById('slotLoader');
    const slotGrid = document.getElementById('slotGrid');
    const slotError = document.getElementById('slotError');
    const selectedBadge = document.getElementById('selectedSlotBadge');
    const selectedLabel = document.getElementById('selectedSlotLabel');

    function resetSlots() {
        slotGrid.style.display = 'none';
        slotGrid.innerHTML = '';
        slotError.style.display = 'none';
        selectedBadge.style.display = 'none';
        slotInput.value = '';
        submitBtn.disabled = true;
    }

    function loadSlots() {
        const doctorId = doctorSel.value;
        const date = dateInput.value;

        if (!doctorId || !date) {
            resetSlots();
            slotPlaceholder.style.display = 'block';
            slotLoader.style.display = 'none';
            return;
        }

        slotPlaceholder.style.display = 'none';
        slotLoader.style.display = 'block';
        slotGrid.style.display = 'none';
        slotError.style.display = 'none';
        selectedBadge.style.display = 'none';
        slotInput.value = '';
        submitBtn.disabled = true;

        fetch('/Admin/Appointments/GetAvailableSlots?doctorId=' + encodeURIComponent(doctorId) + '&date=' + encodeURIComponent(date))
            .then(function(r) { return r.json(); })
            .then(function(slots) {
                slotLoader.style.display = 'none';

                if (!slots || slots.length === 0) {
                    slotError.style.display = 'block';
                    return;
                }

                slotGrid.innerHTML = '';
                slots.forEach(function(slot) {
                    var col = document.createElement('div');
                    col.className = 'col-6 col-sm-4 col-md-3';
                    var btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'slot-btn';
                    btn.textContent = slot;
                    btn.addEventListener('click', function() {
                        // Deselect all
                        document.querySelectorAll('.slot-btn').forEach(function(b) { b.classList.remove('selected'); });
                        btn.classList.add('selected');
                        slotInput.value = slot;
                        selectedLabel.textContent = slot;
                        selectedBadge.style.display = 'block';
                        submitBtn.disabled = false;
                    });
                    col.appendChild(btn);
                    slotGrid.appendChild(col);
                });

                slotGrid.style.display = 'flex';
                slotGrid.style.flexWrap = 'wrap';
            })
            .catch(function(err) {
                slotLoader.style.display = 'none';
                slotError.style.display = 'block';
                slotError.textContent = 'Error loading slots. Please try again.';
                console.error('Slot load error:', err);
            });
    }

    doctorSel.addEventListener('change', loadSlots);
    dateInput.addEventListener('change', loadSlots);

    // Form validation: ensure a slot is selected before submitting
    document.getElementById('createForm').addEventListener('submit', function(e) {
        if (!slotInput.value) {
            e.preventDefault();
            alert('Please select a time slot before creating the appointment.');
        }
    });
</script>
}
