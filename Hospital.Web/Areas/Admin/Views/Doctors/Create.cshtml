@model Hospital.ViewModels.ApplicationUserViewModel

@{
    ViewData["Title"] = "Add New Doctor";
}

<div class="container-fluid px-4 py-3">
    <div class="mb-4">
        <h1 class="h3 mb-0 text-gray-800">Add New Doctor</h1>
        <p class="text-muted small mb-0">Complete the form below to register a new medical specialist.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10">
            <div class="card shadow mb-4 border-0">
                <div class="card-header py-3 bg-primary text-white">
                    <h6 class="m-0 font-weight-bold"><i class="fas fa-user-plus me-2"></i>Doctor Information</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-bold small text-uppercase text-muted">Full Name</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-primary"></i></span>
                                    <input asp-for="Name" class="form-control border-start-0" placeholder="Dr. John Doe" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-bold small text-uppercase text-muted">Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-envelope text-primary"></i></span>
                                    <input asp-for="Email" class="form-control border-start-0" type="email" placeholder="doctor@hospital.com" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Password" class="form-label fw-bold small text-uppercase text-muted">Initial Password</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-primary"></i></span>
                                    <input asp-for="Password" class="form-control border-start-0" type="password" placeholder="••••••••" />
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Specialist" class="form-label fw-bold small text-uppercase text-muted">Specialization</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-stethoscope text-primary"></i></span>
                                    <input asp-for="Specialist" class="form-control border-start-0" placeholder="e.g. Cardiology" />
                                </div>
                                <span asp-validation-for="Specialist" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Gender" class="form-label fw-bold small text-uppercase text-muted">Gender</label>
                                <select asp-for="Gender" class="form-select" asp-items="Html.GetEnumSelectList<Hospital.Models.Gender>()">
                                    <option value="">-- Select Gender --</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="City" class="form-label fw-bold small text-uppercase text-muted">City / Location</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-map-marker-alt text-primary"></i></span>
                                    <input asp-for="City" class="form-control border-start-0" placeholder="City Name" />
                                </div>
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>
                        </div>

                        <input type="hidden" asp-for="IsDoctor" value="true" />

                        <hr class="my-4">

                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">Save Doctor</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
