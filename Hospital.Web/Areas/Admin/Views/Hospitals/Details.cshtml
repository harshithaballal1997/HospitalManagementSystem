@model Hospital.ViewModels.HospitalInfoViewModel

@{
    ViewData["Title"] = "Hospital Details";
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Hospital Details</h1>
            <p class="text-muted small mb-0">Full profile for <strong>@Model.Name</strong></p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-medical-sm btn-medical-edit">
                <i class="fas fa-edit me-2"></i>Edit Hospital
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i>Back to List
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Info Card -->
        <div class="col-xl-8 col-lg-7">
            <div class="card shadow border-0 mb-4 h-100">
                <div class="card-header py-3 bg-primary text-white d-flex align-items-center">
                    <h6 class="m-0 font-weight-bold"><i class="fas fa-hospital me-2"></i>Hospital Information</h6>
                    @if (!string.IsNullOrEmpty(Model.RegistrationNumber))
                    {
                        <span class="ms-auto badge bg-white text-primary px-3 py-2">
                            <i class="fas fa-certificate me-1"></i>@Model.RegistrationNumber
                        </span>
                    }
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="info-group mb-4">
                                <label class="small text-uppercase fw-bold text-muted mb-1 d-block">Hospital Name</label>
                                <div class="d-flex align-items-center">
                                    <div class="icon-shape bg-primary bg-opacity-10 text-primary rounded-circle me-3 text-center" style="width: 40px; height: 40px; line-height:38px;">
                                        <i class="fas fa-building"></i>
                                    </div>
                                    <span class="fs-5 fw-bold text-dark">@Model.Name</span>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-group mb-4">
                                <label class="small text-uppercase fw-bold text-muted mb-1 d-block">Facility Type</label>
                                <div class="d-flex align-items-center">
                                    <div class="icon-shape bg-info bg-opacity-10 text-info rounded-circle me-3 text-center" style="width: 40px; height: 40px; line-height:38px;">
                                        <i class="fas fa-tags"></i>
                                    </div>
                                    <span class="badge bg-medical-type px-3 py-2">@Model.Type</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-0">
                            <div class="divider border-bottom mb-4"></div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-group mb-4">
                                <label class="small text-uppercase fw-bold text-muted mb-1 d-block">Services Offered</label>
                                <div class="d-flex align-items-center">
                                    <div class="icon-shape bg-success bg-opacity-10 text-success rounded-circle me-3 text-center" style="width: 40px; height: 40px; line-height:38px;">
                                        <i class="fas fa-stethoscope"></i>
                                    </div>
                                    <span class="text-dark">@(string.IsNullOrEmpty(Model.Services) ? "General Hospital Services" : Model.Services)</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-group mb-4">
                                <label class="small text-uppercase fw-bold text-muted mb-1 d-block">Operating Hours</label>
                                <div class="d-flex align-items-center">
                                    <div class="icon-shape bg-warning bg-opacity-10 text-warning rounded-circle me-3 text-center" style="width: 40px; height: 40px; line-height:38px;">
                                        <i class="fas fa-clock"></i>
                                    </div>
                                    <span class="text-dark">@(string.IsNullOrEmpty(Model.OperatingHours) ? "24/7 Emergency Services" : Model.OperatingHours)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar / Branding Card -->
        <div class="col-xl-4 col-lg-5">
            <div class="card shadow border-0 mb-4 text-center p-4">
                <div class="branding-container mb-3">
                    @if (!string.IsNullOrEmpty(Model.LogoUrl))
                    {
                        <img src="@Model.LogoUrl" alt="@Model.Name Logo" class="img-fluid rounded shadow-sm border mb-3" style="max-height: 120px;" />
                    }
                    else
                    {
                        <div class="bg-light rounded p-4 mb-3 border d-inline-block">
                            <i class="fas fa-hospital fa-4x text-muted"></i>
                        </div>
                    }
                    <h5 class="fw-bold mb-1">@Model.Name</h5>
                    <p class="text-muted small">ID: @Model.Id</p>
                </div>
                <div class="d-grid gap-2 mt-2">
                    <a href="mailto:@Model.EmailAddress" class="btn btn-medical-sm btn-medical-details py-2">
                        <i class="fas fa-envelope me-2"></i>Send Email
                    </a>
                    @if (!string.IsNullOrEmpty(Model.WebsiteUrl))
                    {
                        <a href="@Model.WebsiteUrl" target="_blank" class="btn btn-medical-sm btn-medical-create py-2">
                            <i class="fas fa-external-link-alt me-2"></i>Visit Website
                        </a>
                    }
                </div>
            </div>

            <!-- Contact Summary Card -->
            <div class="card shadow border-0 mb-4">
                <div class="card-header py-3 bg-medical-contact text-white">
                    <h6 class="m-0 font-weight-bold"><i class="fas fa-phone-alt me-2"></i>Contact Details</h6>
                </div>
                <div class="card-body p-4">
                    <div class="contact-item mb-3 d-flex align-items-center">
                        <i class="fas fa-phone text-primary me-3 w-20px"></i>
                        <div>
                            <span class="d-block small text-muted">Phone</span>
                            <span class="fw-bold">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not Provided" : Model.PhoneNumber)</span>
                        </div>
                    </div>
                    <div class="contact-item mb-0 d-flex align-items-center">
                        <i class="fas fa-envelope text-primary me-3 w-20px"></i>
                        <div>
                            <span class="d-block small text-muted">Email</span>
                            <span class="fw-bold">@(string.IsNullOrEmpty(Model.EmailAddress) ? "Not Provided" : Model.EmailAddress)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Location Footer Card -->
        <div class="col-12">
            <div class="card shadow border-0 mb-4 overflow-hidden">
                <div class="row g-0 h-100">
                    <div class="col-md-4 bg-medical-location text-white p-4 d-flex flex-column justify-content-center">
                        <h5 class="fw-bold"><i class="fas fa-map-marked-alt me-2"></i>Location Info</h5>
                        <p class="mb-0 opacity-75">Full verification of the facility address.</p>
                    </div>
                    <div class="col-md-8">
                        <div class="card-body p-4">
                            <div class="row">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <label class="small text-uppercase fw-bold text-muted mb-1 d-block">Street Address</label>
                                    <p class="text-dark fw-bold mb-0">@(string.IsNullOrEmpty(Model.StreetAddress) ? "No address on file" : Model.StreetAddress)</p>
                                </div>
                                <div class="col-md-6">
                                    <div class="row">
                                        <div class="col-6">
                                            <label class="small text-uppercase fw-bold text-muted mb-1 d-block">City</label>
                                            <p class="text-dark fw-bold mb-0">@Model.City</p>
                                        </div>
                                        <div class="col-6">
                                            <label class="small text-uppercase fw-bold text-muted mb-1 d-block">Pincode</label>
                                            <p class="text-dark fw-bold mb-0">@Model.Pincode</p>
                                        </div>
                                        <div class="col-12 mt-3">
                                            <label class="small text-uppercase fw-bold text-muted mb-1 d-block">Country</label>
                                            <p class="text-dark fw-bold mb-0"><i class="fas fa-flag-usa me-2 opacity-50"></i>@Model.Country</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-medical-type { background-color: rgba(78, 115, 223, 0.1); color: #4e73df; }
    .bg-medical-contact { background-color: #1cc88a; }
    .bg-medical-location { background-color: #f6c23e; }
    .w-20px { width: 20px; }
    .icon-shape { display: flex; align-items: center; justify-content: center; }
</style>
