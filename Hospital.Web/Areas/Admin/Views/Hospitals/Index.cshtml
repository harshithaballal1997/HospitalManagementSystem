@using Hospital.Utilities
@model PagedResult<Hospital.ViewModels.HospitalInfoViewModel>

@{
    ViewData["Title"] = "Index";
}

<div class="container-fluid px-4 py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Hospital Management</h1>
            <p class="text-muted small mb-0">Manage hospital facilities and contact information.</p>
        </div>
        <a asp-action="Create" class="btn btn-medical btn-medical-create">
            <i class="fas fa-plus"></i> Add New Hospital
        </a>
    </div>

    <div class="modern-card">
        <div class="table-responsive">
            <table class="table table-medical align-middle mb-0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>City</th>
                        <th>PinCode</th>
                        <th>Country</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><span class="fw-bold text-primary">@item.Name</span></td>
                            <td>@item.Type</td>
                            <td>@item.City</td>
                            <td>@item.Pincode</td>
                            <td>@item.Country</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-medical-sm btn-medical-edit">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-medical-sm btn-medical-details">
                                        <i class="fas fa-info-circle"></i> Details
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-medical-sm btn-medical-delete">
                                        <i class="fas fa-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<cs-pager cs-paging-pagesize=(int)Model.PageSize
          cs-paging-pagenumber=(int)Model.PageNumber
          cs-paging-totalitems=(int)Model.TotalItems
          cs-pagenumber-param="pageNumber"
          asp-controller="Hospitals"

          asp-action="Index"
          cs-pager-li-current-class="page-item active"
          cs-pager-li-other-class="page-item"
          cs-pager-li-non-active-class="page-item disabled"
          cs-pager-link-current-class="page-link"
          cs-pager-link-other-class="page-link">
      </cs-pager>