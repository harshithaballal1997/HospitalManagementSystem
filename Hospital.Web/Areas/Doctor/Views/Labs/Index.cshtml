@model Hospital.Utilities.PagedResult<Hospital.ViewModels.LabViewModel>

@{
    ViewData["Title"] = "Clinical Dashboard - Lab Results";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-primary">Clinical Dashboard</h1>
            <p class="text-muted small mb-0">Real-time Patient Vitals & Lab Monitoring</p>
        </div>
        <div>
            <a class="btn btn-medical btn-medical-create" asp-action="Create">
                <i class="fas fa-plus"></i> Add New Record
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="modern-card bg-primary text-white d-flex align-items-center">
                <div class="rounded-circle bg-white bg-opacity-25 p-3 me-3">
                    <i class="fas fa-flask fs-4"></i>
                </div>
                <div>
                    <h6 class="mb-0 opacity-75 small">Total Reports</h6>
                    <h3 class="mb-0 fw-bold">@Model.TotalItems</h3>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="modern-card bg-info text-white d-flex align-items-center">
                <div class="rounded-circle bg-white bg-opacity-25 p-3 me-3">
                    <i class="fas fa-heartbeat fs-4"></i>
                </div>
                <div>
                    <h6 class="mb-0 opacity-75 small">Active Monitoring</h6>
                    <h3 class="mb-0 fw-bold">Live</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="table-medical shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3 d-flex align-items-center">
            <i class="fas fa-microscope text-primary me-2"></i>
            <h6 class="mb-0 fw-bold">Patient Lab Results & Vitals</h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-medical-light">
                        <tr class="text-primary small fw-bold">
                            <th class="ps-4">Lab #</th>
                            <th>Patient</th>
                            <th>Vitals (BP/Temp)</th>
                            <th class="text-center">BMI (Auto)</th>
                            <th>Test Type (Code)</th>
                            <th>Test Value</th>
                            <th>AI Summary / Results</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Data)
                        {
                            var bmi = item.Height > 0 ? (item.Weight / Math.Pow(item.Height / 100.0, 2)) : 0;
                            <tr>
                                <td class="ps-4 fw-bold text-primary">@item.LabNumber</td>
                                <td class="fw-semibold">@item.PatientName</td>
                                <td style="min-width: 150px;">
                                    <span class="badge bg-medical-light text-primary border border-primary border-opacity-25 px-2 py-1">
                                        <i class="fas fa-tachometer-alt me-1 opacity-50"></i> @item.BloodPressure mmHg
                                    </span>
                                    <span class="badge bg-medical-light text-warning border border-warning border-opacity-25 px-2 py-1 ms-1">
                                        <i class="fas fa-thermometer-half me-1 opacity-50"></i> @item.Temperature °C
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (bmi > 0)
                                    {
                                        <div class="d-inline-flex flex-column align-items-center">
                                            <span class="badge @(bmi < 18.5 || bmi > 25 ? "bg-danger" : "bg-success") bg-opacity-10 @(bmi < 18.5 || bmi > 25 ? "text-danger" : "text-success") px-3 py-1">
                                                @bmi.ToString("F1")
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">N/A</span>
                                    }
                                </td>
                                <td>
                                    <span class="d-block">@item.TestType</span>
                                    <span class="text-muted smaller">@item.TestCode</span>
                                </td>
                                <td>
                                    @if(item.TestValue.HasValue)
                                    {
                                        var isHigh = item.TestValue.Value > 100;
                                        <span class="badge @(isHigh ? "bg-danger" : "bg-primary") bg-opacity-10 @(isHigh ? "text-danger" : "text-primary") fw-bold p-2 pulse-warning">
                                            @item.TestValue.Value
                                            @if(isHigh) { <i class="fas fa-exclamation-triangle ms-1"></i> }
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="text-truncate" style="max-width: 250px;" title="@item.TestResults">
                                        @if (item.TestResults != null && item.TestResults.Contains("### AI"))
                                        {
                                            <span class="text-primary fw-bold small"><i class="fas fa-robot me-1"></i> AI Insights Available</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">@item.TestResults</span>
                                        }
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-info" onclick="loadSummary('@item.PatientId')" title="View AI Insights">
                                            <i class="fas fa-brain"></i>
                                        </button>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Enhanced Pagination -->
            <div class="d-flex justify-content-between align-items-center border-top px-4 py-3">
                <div class="text-muted small">
                    Showing @Model.Data.Count of @Model.TotalItems reports
                </div>
                <nav aria-label="Page navigation">
                    <ul class="pagination pagination-sm mb-0">
                        @for (int i = 1; i <= Math.Ceiling((double)Model.TotalItems / Model.PageSize); i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-pageNumber="@i">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- AI Summary Modal -->
<div class="modal fade" id="summaryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">AI Patient Insights</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="summaryContent" class="mb-4">
                    Loading AI-generated summary...
                </div>
                <hr />
                <div id="historyContent">
                    Loading medical history...
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadSummary(patientId) {
            const modal = new bootstrap.Modal(document.getElementById('summaryModal'));
            const summaryContent = document.getElementById('summaryContent');
            const historyContent = document.getElementById('historyContent');
            
            summaryContent.innerHTML = '<div class="text-center"><div class="spinner-border text-info" role="status"></div><p class="small mt-2">Summarizing clinical history...</p></div>';
            historyContent.innerHTML = '<div class="text-center"><div class="spinner-border text-secondary" role="status"></div><p class="small mt-2">Fetching lab records...</p></div>';
            
            modal.show();
            
            // Fetch AI Summary
            fetch(`/Doctor/Labs/PatientSummary?patientId=${patientId}`)
                .then(response => response.text())
                .then(data => {
                    summaryContent.innerHTML = '<div class="markdown-body">' + data + '</div>';
                })
                .catch(err => {
                    summaryContent.innerHTML = '<div class="alert alert-danger">Error loading summary.</div>';
                });

            // Fetch Lab History
            fetch(`/Doctor/Labs/GetHistory?patientId=${patientId}`)
                .then(response => response.text())
                .then(data => {
                    historyContent.innerHTML = data;
                })
                .catch(err => {
                    historyContent.innerHTML = '<div class="alert alert-danger">Error loading history.</div>';
                });
        }
    </script>
}
