<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hospital.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hospital.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Hospital.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="nav-link text-dark" asp-area="admin" asp-controller="Dashboard" asp-action="Index">Admin Dashboard</a>
                            }
                            else
                            {
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            }
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Privacy" asp-action="Index">Privacy</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="admin" asp-controller="Hospitals" asp-action="Index">Hospital</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="admin" asp-controller="RoomAllocation" asp-action="Index">Room Allocation</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="admin" asp-controller="Users" asp-action="Index">Patients</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="admin" asp-controller="Doctors" asp-action="Index">Doctors</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="admin" asp-controller="Appointments" asp-action="Index">Appointments</a>
                            </li>
                        }
                        @if (User.IsInRole("Doctor") || User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="doctor" asp-controller="Labs" asp-action="Index">Clinical Dashboard</a>
                            </li>
                        }
                        
                        @if (User.IsInRole("Doctor"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="doctor" asp-controller="Availability" asp-action="Index">My Availability</a>
                            </li>
                        }
                        @if (User.IsInRole("Patient"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="patient" asp-controller="Booking" asp-action="Index">Book Appointment</a>
                            </li>
                        }

                    </ul>
                    <partial name="_LoginPartial"/>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - Hospital.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- AI Chatbot Widget -->
    @if (User.Identity.IsAuthenticated)
    {
        <div id="aiChatWidget" class="ai-chat-widget">
            <button id="aiChatToggle" class="btn btn-primary chat-toggle-btn shadow-lg">
                <i class="fas fa-robot me-2"></i> Hospital AI
            </button>
            <div id="aiChatWindow" class="chat-window shadow-lg" style="display:none;">
                <div class="chat-header bg-primary text-white p-3 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0"><i class="fas fa-robot me-2"></i> Secure AI Assistant</h6>
                    <button id="aiChatClose" class="btn-close btn-close-white" aria-label="Close"></button>
                </div>
                <div id="aiChatMessages" class="chat-body p-3 bg-light">
                    <div class="chat-msg bot-msg">
                        <span class="chat-sender">Hospital AI:</span> Hello! I am your secure digital assistant. How can I help you today?
                    </div>
                </div>
                <div class="chat-footer p-2 bg-white border-top d-flex">
                    <input type="text" id="aiChatInput" class="form-control me-2" placeholder="Ask a question..." autocomplete="off" />
                    <button id="aiChatSend" class="btn btn-primary"><i class="fas fa-paper-plane"></i></button>
                </div>
            </div>
        </div>
    }

    <style>
        .ai-chat-widget { position: fixed; bottom: 30px; right: 30px; z-index: 1050; font-family: 'Inter', sans-serif; }
        .chat-toggle-btn { border-radius: 50px; padding: 12px 20px; font-weight: 600; font-size: 1rem; }
        .chat-window { position: absolute; bottom: 60px; right: 0; width: 340px; height: 450px; background: #fff; border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; border: 1px solid rgba(0,0,0,0.1); }
        .chat-body { flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
        .chat-msg { padding: 10px 14px; border-radius: 8px; font-size: 0.9rem; line-height: 1.4; max-width: 85%; word-wrap: break-word; }
        .bot-msg { align-self: flex-start; background: #e9ecef; color: #212529; border-bottom-left-radius: 2px; }
        .user-msg { align-self: flex-end; background: #0d6efd; color: #fff; border-bottom-right-radius: 2px; }
        .chat-sender { font-weight: 700; display: block; margin-bottom: 2px; font-size: 0.8rem; opacity: 0.8; }
        .typing { display: flex; align-items: center; gap: 4px; padding: 14px !important; }
        .dot { width: 6px; height: 6px; background: #6c757d; border-radius: 50%; animation: blink 1.4s infinite both; }
        .dot:nth-child(1) { animation-delay: 0.2s; }
        .dot:nth-child(2) { animation-delay: 0.4s; }
        .dot:nth-child(3) { animation-delay: 0.6s; }
        @@keyframes blink { 0% { opacity: .2; } 20% { opacity: 1; } 100% { opacity: .2; } }
    </style>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/chat-widget.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
